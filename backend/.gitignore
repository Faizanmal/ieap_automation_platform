# IEAP - Git Ignore

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================================================
# Virtual Environments
# ============================================================================
venv/
.venv/
ENV/
env/

# ============================================================================
# IDE / Editor
# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-workspace
*.sublime-project

# ============================================================================
# Testing
# ============================================================================
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
junit*.xml
pytest-report.xml

# ============================================================================
# Type Checking
# ============================================================================
.mypy_cache/
.dmypy.json
dmypy.json

# ============================================================================
# Jupyter Notebooks
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================================
# Environment & Config
# ============================================================================
.env
.env.*
!.env.example
*.local
secrets.yaml
secrets.json

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
*.log.*
log*.txt

# ============================================================================
# Database
# ============================================================================
*.db
*.sqlite
*.sqlite3
*.sql.gz

# ============================================================================
# Models & Data
# ============================================================================
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
!models/.gitkeep
data/*.csv
data/*.json
!data/sample*.csv
!data/sample*.json

# ============================================================================
# Docker
# ============================================================================
.docker/

# ============================================================================
# Kubernetes
# ============================================================================
*.kubeconfig
kubeconfig

# ============================================================================
# Build Artifacts
# ============================================================================
*.tar.gz
*.zip

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
Thumbs.db
*.bak

# ============================================================================
# Celery
# ============================================================================
celerybeat-schedule
celerybeat.pid
celery*.db

# ============================================================================
# Profiling
# ============================================================================
*.prof
*.lprof
profile_output/

# ============================================================================
# Misc
# ============================================================================
*.cache
.cache/
tmp/
temp/
*.tmp
*.temp
